   "opticalwaveguides" {:create create-optical-waveguide :list list-optical-waveguides :get get-optical-waveguide :update update-optical-waveguide :delete delete-optical-waveguide}
   "modulators" {:create create-modulator :list list-modulators :get get-modulator :update update-modulator :delete delete-modulator}
   "photodetectors" {:create create-photodetector :list list-photodetectors :get get-photodetector :update update-photodetector :delete delete-photodetector}
   "lasersources" {:create create-laser-source :list list-laser-sources :get get-laser-source :update update-laser-source :delete delete-laser-source}
   "wavelengthchannels" {:create create-wavelength-channel :list list-wavelength-channels :get get-wavelength-channel :update update-wavelength-channel :delete delete-wavelength-channel}})

(defn- expand-opts [params]
  (when-let [x (:expand params)]
    {:expand (set (map keyword (str/split (str x) #",")))}))

(defn dispatch
  "Route an HTTP-ish request through `routes` to the CRUD fns.
   req: {:method (:get/:post/:patch/:delete) :path /v1/<coll>[/<id>] :params {} :body {}}.
   Returns {:status int :body any} — the runnable L4 service surface."
  [port {:keys [method path params body]}]
  (let [segs (->> (str/split (or path "") #"/") (remove str/blank?) vec)
        coll (get segs 1)
        id   (get segs 2)
        h    (get handlers coll)
        params (or params {})]
    (cond
      (nil? h) {:status 404 :body {:error "unknown collection"}}
      (and (= method :post) (nil? id)) {:status 201 :body ((:create h) port (or body params))}
      (and (= method :get) (nil? id)) {:status 200 :body ((:list h) port params)}
      (and (= method :get) id) (if-let [r ((:get h) port id (expand-opts params))]
                                 {:status 200 :body r} {:status 404 :body {:error "not found"}})
      (and (#{:patch :put} method) id) (if-let [r ((:update h) port id (or body params))]
                                         {:status 200 :body r} {:status 404 :body {:error "not found"}})
      (and (= method :delete) id) {:status 200 :body ((:delete h) port id)}
      :else {:status 405 :body {:error "method not allowed"}})))

