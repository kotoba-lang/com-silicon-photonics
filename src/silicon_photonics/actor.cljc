(defn create-wavelength-channel
  "Create a WavelengthChannel."
  [port data]
  (require-fields data ["lambdaNm" "spacingGhz"])
  (let [id (new-id "siph_wav")
        e {:db/id id
           :silicon_photonics.WavelengthChannel/id id
           :silicon_photonics.WavelengthChannel/dieId (get data :dieId)
           :silicon_photonics.WavelengthChannel/lambdaNm (as-double (get data :lambdaNm))
           :silicon_photonics.WavelengthChannel/spacingGhz (as-double (get data :spacingGhz))
           :silicon_photonics.WavelengthChannel/dataRateGbps (as-double (get data :dataRateGbps))
           :silicon_photonics.WavelengthChannel/createdAt (now)
           :silicon_photonics.WavelengthChannel/updatedAt (now)}]
    (-transact port [e])
    e))

(defn list-wavelength-channels
  "List WavelengthChannel with optional filtering + cursor pagination → L4 list map.
   opts: {:filter {<attr-kw> v} :limit N :starting-after <db/id>}."
  ([port] (list-wavelength-channels port {}))
  ([port opts]
   (let [rows (mapv (fn [e] (-pull port e)) (-find-by-attr port :silicon_photonics.WavelengthChannel/id))
         rows (apply-filters rows (:filter opts) [:silicon_photonics.WavelengthChannel/dieId :silicon_photonics.WavelengthChannel/lambdaNm :silicon_photonics.WavelengthChannel/spacingGhz :silicon_photonics.WavelengthChannel/dataRateGbps])]
     (paginate rows opts))))

(defn get-wavelength-channel
