(defn create-photonic-die
  "Create a PhotonicDie."
  [port data]
  (require-fields data ["name" "platform"])
  (let [id (new-id "siph_pho")
        e {:db/id id
           :silicon_photonics.PhotonicDie/id id
           :silicon_photonics.PhotonicDie/name (get data :name)
           :silicon_photonics.PhotonicDie/platform (get data :platform)
           :silicon_photonics.PhotonicDie/processNode (get data :processNode)
           :silicon_photonics.PhotonicDie/areaMm2 (as-double (get data :areaMm2))
           :silicon_photonics.PhotonicDie/createdAt (now)
           :silicon_photonics.PhotonicDie/updatedAt (now)}]
    (-transact port [e])
    e))

(defn list-photonic-dies
  "List PhotonicDie with optional filtering + cursor pagination → L4 list map.
   opts: {:filter {<attr-kw> v} :limit N :starting-after <db/id>}."
  ([port] (list-photonic-dies port {}))
  ([port opts]
   (let [rows (mapv (fn [e] (-pull port e)) (-find-by-attr port :silicon_photonics.PhotonicDie/id))
         rows (apply-filters rows (:filter opts) [:silicon_photonics.PhotonicDie/name :silicon_photonics.PhotonicDie/platform :silicon_photonics.PhotonicDie/processNode :silicon_photonics.PhotonicDie/areaMm2])]
     (paginate rows opts))))

(defn get-photonic-die
  "Retrieve a PhotonicDie by id; opts {:expand #{:field}} inlines referenced entities. nil if absent."
  ([port id] (get-photonic-die port id nil))
  ([port id opts]
   (when-let [rec (-pull port id)]
     (let [want (:expand opts)]
       (cond-> rec)))))

(defn update-photonic-die
  "Update a PhotonicDie; returns the new entity map, or nil if absent."
  [port id data]
  (when (-pull port id)
    (let [sets (-> []
                   (cond-> (contains? data :name) (conj [:db/add id :silicon_photonics.PhotonicDie/name (get data :name)]))
                   (cond-> (contains? data :platform) (conj [:db/add id :silicon_photonics.PhotonicDie/platform (get data :platform)]))
                   (cond-> (contains? data :processNode) (conj [:db/add id :silicon_photonics.PhotonicDie/processNode (get data :processNode)]))
